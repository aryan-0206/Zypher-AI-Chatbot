# ── Zypher AI — Environment Variables ──────────────────────
# Copy this file to backend/.env and fill in your values.
# NEVER commit the actual .env file to git!

# Required: Get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Server config (optional — defaults shown)
PORT=5001
API_PORT=5001
HOST=0.0.0.0
FLASK_ENV=development
FLASK_DEBUG=True

# CORS — comma-separated allowed origins (* = all)
ALLOWED_ORIGINS=*
